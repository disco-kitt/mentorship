   "source": [
    "## 3. Load CSVs\n",
    "\n",
    "Choose one workflow:\n",
    "\n",
    "- **Sample data:** use the bundled synthetic CSVs. Best for GitHub demos.\n",
    "- **Upload data:** in Google Colab, upload one student CSV and one alumni/mentor CSV.\n",
    "\n",
    "Set `USE_UPLOAD = True` only when running in Colab and you want to upload files."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "2be724e1",
   "metadata": {},
   "outputs": [],
   "source": [
    "USE_UPLOAD = False  # Change to True in Google Colab to upload CSVs.\n",
    "\n",
    "if USE_UPLOAD:\n",
    "    uploaded = load_from_colab_upload()\n",
    "    if uploaded is None:\n",
    "        raise RuntimeError(\"CSV upload is only available in Google Colab. Set USE_UPLOAD = False to use sample data.\")\n",
    "    students_raw, alumni_raw = uploaded\n",
    "else:\n",
    "    students_raw, alumni_raw = load_sample_data(project_root)\n",
    "\n",
    "print(f\"Loaded {len(students_raw)} students and {len(alumni_raw)} alumni/mentors.\")"
