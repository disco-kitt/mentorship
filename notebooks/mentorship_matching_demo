    "\n",
    "from src.loader import load_sample_data, load_csvs, load_from_colab_upload\n",
    "from src.preprocessing import preprocess_students, preprocess_alumni\n",
    "from src.scoring import score_all_pairs\n",
    "from src.matching import assign_matches\n",
    "from src.reporting import export_matches\n",
    "from src.config import WEIGHTS\n",
    "\n",
    "pd.set_option(\"display.max_colwidth\", 120)\n",
    "WEIGHTS"
   ]
